# Copy this file to .env only when your deployment tooling loads environment files.
# Do not commit .env or real Tencent Cloud credentials.
DASHSCOPE_API_KEY=

# Use the official Tencent Cloud CLS MCP Server as an independent HTTP service.
CLS_MCP_ENABLED=true
CLS_MOCK_ENABLED=false
CLS_MCP_URL=http://localhost:3000
CLS_MCP_PORT=3000
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=

# Set to internal.tencentcloudapi.com only when OpsMind runs in a Tencent Cloud VPC.
TENCENTCLOUD_API_BASE_HOST=tencentcloudapi.com
CLS_MCP_REQUEST_TIMEOUT=60s
CLS_MCP_MAX_LENGTH=12000

# OIDC/SSO 配置：issuer、audience 和公开客户端 ID 未配置完整前不要启用认证。
# tenant/user 身份只从后端验证后的 JWT 获取，不接受聊天请求体传入的身份。
OPSMIND_SECURITY_ENABLED=false
OIDC_ISSUER_URI=
OIDC_AUDIENCE=
OIDC_CLIENT_ID=
OIDC_TENANT_CLAIM=tenant_id
OIDC_SCOPES=openid profile
OPSMIND_DEV_TENANT_ID=dev-tenant
OPSMIND_DEV_USER_ID=dev-user

# 本地 Keycloak 开发服务；共享环境使用前必须更换默认管理密码。
KEYCLOAK_PORT=8180
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-now
# After Keycloak is running, set the OIDC values above to:
# OPSMIND_SECURITY_ENABLED=true
# OIDC_ISSUER_URI=http://localhost:8180/realms/opsmind
# OIDC_AUDIENCE=opsmind-api
# OIDC_CLIENT_ID=opsmind-web
MYSQL_URL=jdbc:mysql://localhost:3307/opsmind?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=opsmind
MYSQL_PASSWORD=opsmind
REDIS_HOST=localhost
REDIS_PORT=6379

# 仅在数据处理政策允许把脱敏候选记忆发送给当前 LLM 服务后启用。
LONG_MEMORY_ENABLED=true
LONG_MEMORY_EXTRACTION_INTERVAL=5
LONG_MEMORY_SELECTOR_TIMEOUT_MS=2000
