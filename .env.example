# Copy this file to .env only when your deployment tooling loads environment files.
# Do not commit .env or real Tencent Cloud credentials.
DASHSCOPE_API_KEY=

# Use the official Tencent Cloud CLS MCP Server as an independent HTTP service.
CLS_MCP_ENABLED=true
CLS_MOCK_ENABLED=false
CLS_MCP_URL=http://localhost:3000
CLS_MCP_PORT=3000
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=

# Set to internal.tencentcloudapi.com only when OpsMind runs in a Tencent Cloud VPC.
TENCENTCLOUD_API_BASE_HOST=tencentcloudapi.com
CLS_MCP_REQUEST_TIMEOUT=60s
CLS_MCP_MAX_LENGTH=12000
